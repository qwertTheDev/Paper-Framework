local PaperFramework = {}

--//Services
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

--//Constants
local IsServer = RunService:IsServer()

local Pages = {}
local State = "Idle" -- "Idle", "Initializing", "Started"
local Config = {}

---

--//Lifecycle

function PaperFramework:Init()
	assert(State == "Idle", "[Paper] Init() can only be called once")

	self:AddPages(script.Shared) -- Loaded automatically

	State = "Initializing"

	local environment = IsServer and "Server" or "Client"

	print("Paper is initializing your", environment, "pages..")

	if IsServer then
		local Server = script.Server
		local AssetsServer = script.Assets.Server

		Server.Name = "PaperServer"
		Server.Parent = game:GetService("ServerScriptService")

		AssetsServer.Name = "ServerAssets"
		AssetsServer.Parent = ServerStorage
	end

	for _, page in pairs(Pages) do
		if type(page.Init) == "function" then
			local success, err = pcall(page.Init, page, self)

			if not success then
				warn("[Paper] Error initializing page", page.Name, ":", err)
			end
		end
	end
end

function PaperFramework:Start()
	assert(State == "Initializing", "[Paper] Start() can only be called after Init")

	State = "Started"

	local environment = IsServer and "Server" or "Client"

	print("Paper has finished starting your", environment, "pages!")

	for _, page in pairs(Pages) do
		if type(page.Start) == "function" then
			local success, err = pcall(page.Start, page)

			if not success then
				warn("[Paper] Error starting page", page.Name, ":", err)
			end
		end
	end
end

--//Paper Functions

--[[
	Manually register a Page using its table.
	The ModuleScript should have a unique Name.
]]
function PaperFramework:AddPage(pageTemplate)
	assert(type(pageTemplate) == "table", "[Paper] Page must be a table")
	assert(pageTemplate.Name, "[Paper] Page missing Name")
	assert(State == "Idle", "[Paper] Pages cannot be added after Paper is initialized")

	assert(not Pages[pageTemplate.Name],
		("[Paper] Duplicate page: %s"):format(pageTemplate.Name)
	)

	pageTemplate.Paper = self

	Pages[pageTemplate.Name] = pageTemplate
end

--[[
	Register multiple Pages from a folder.
	The folder should contain ModuleScripts only;
	Each ModuleScript should return a Page table;
	Each ModuleScript should have a unique Name.
]]
function PaperFramework:AddPages(folder : Instance)
	for _, item in ipairs(folder:GetChildren()) do
		if item:IsA("Folder") then
			self:AddPages(item)

		elseif item:IsA("ModuleScript") then
			local ok, result = pcall(require, item)

			if not ok then
				warn("[Paper] Failed to require:", item:GetFullName(), result)
				continue
			end

			if type(result) == "table" and result.Name then
				self:AddPage(result)
			end
		end
	end
end

--[[
	Reads a Page from the current environment.
	Client Pages cannot be accessed from the server and vice versa through this function;
	Do not write to a Page directly through this;
	Each Page should have functions to write to the Page.
]]
function PaperFramework:Read(pageName : string)
	local page = Pages[pageName]

	if not page then
		error(("[Paper] Page '%s' not found"):format(pageName))
	end

	return page
end

--[[
	Automatically adds Pages to their respective Environment.
	Do not use this if you want to keep track of the Pages you add;
	This only works for the Server and Client folders;
	The function works only for the environment which Paper is being ran on.
]]
function PaperFramework:AddAuto()
	local directory = IsServer and "Server" or "Client"
	local folder = script:FindFirstChild(directory)

	if not folder then
		return
	end

	self:AddPages(folder)
end

--[[
	Writes to Paper's configuration table.
	You can store data in Paper's configuration table and use it for your pages.
]]
function PaperFramework:Write(configName : string, configValue, overwrite : boolean)
	local hierarchy = configName:split(".")
	local currentTable = Config

	for i = 1, #hierarchy - 1 do
		local key = hierarchy[i]
		if not currentTable[key] then
			currentTable[key] = {}
		end

		currentTable = currentTable[key]
	end

	local key = hierarchy[#hierarchy]
	if tonumber(key) then
		key = tonumber(key)
	end

	if overwrite or currentTable[key] == nil then
		currentTable[key] = configValue
	else
		table.insert(currentTable[key], configValue)
	end
end

function PaperFramework:ReadConfig(configName : string)
	local hierarchy = configName:split(".")
	local currentTable = Config

	for _, key in ipairs(hierarchy) do
		if tonumber(key) then
			key = tonumber(key)
		end
		
		currentTable = currentTable[key]

		if not currentTable then
			error(("[Paper] Config '%s' not found"):format(configName))
		end
	end

	return currentTable
end

--//Assets
function PaperFramework:GetAsset(assetName : string, assetCategory : string, inShared : boolean)
	local function recursiveSearch(parent : Instance, name : string)
		for _, child in ipairs(parent:GetChildren()) do
			if child.Name == name then
				return child
			end

			local result = recursiveSearch(child, name)
			if result then
				return result
			end
		end
	end

	local assetFolder

	if not IsServer or inShared then
		assetFolder = script.Assets.Shared
	elseif IsServer then
		assetFolder = ServerStorage:FindFirstChild("ServerAssets")
	end
	
	assetFolder = assetFolder:FindFirstChild(assetCategory)

	if not assetFolder then
		warn("[Paper] Asset category not found:", assetCategory)
		return
	end

	return recursiveSearch(assetFolder, assetName)
end

--//Environment Helpers

--[[
	Returns the current environment which Paper is running on.
]]
function PaperFramework:ReadEnvironment()
	return IsServer
end

return PaperFramework
